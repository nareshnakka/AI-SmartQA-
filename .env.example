# Application
APP_NAME=QEOS
APP_ENV=development
SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./qeos.db
# For PostgreSQL: postgresql+asyncpg://qeos:qeos@localhost:5432/qeos

# Redis
REDIS_URL=redis://localhost:6379/0

# QEOS Native Intelligence (default — no external LLM needed)
DEFAULT_LLM_PROVIDER=qeos-native
DEFAULT_LLM_MODEL=qeos-intelligence-v1

# Optional external LLM providers (not required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional: custom trained QEOS neural model (future)
QEOS_MODEL_PATH=
QEOS_ENABLE_NEURAL=false
QEOS_HYBRID_AUTO=true
OLLAMA_MODEL=llama3.2

# Training data collection (auto-captures agent runs for fine-tuning)
QEOS_TRAINING_COLLECT=true
QEOS_TRAINING_DATA_DIR=training/data/collected

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Integrations - GitHub
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Integrations - Bitbucket
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_WEBHOOK_SECRET=

# Integrations - GitLab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_WEBHOOK_SECRET=

# Integrations - Jira
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_WEBHOOK_SECRET=

# Phase 5 — Auth & SSO
QEOS_AUTH_ENABLED=false
QEOS_DEFAULT_ADMIN_EMAIL=admin@qeos.local
QEOS_DEFAULT_ADMIN_PASSWORD=admin
QEOS_SSO_ENABLED=false
QEOS_SSO_ISSUER_URL=
QEOS_SSO_CLIENT_ID=
QEOS_SSO_CLIENT_SECRET=
QEOS_SSO_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# Phase 5 — Monitoring webhooks
DATADOG_WEBHOOK_SECRET=
SENTRY_WEBHOOK_SECRET=

# Playwright runners
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true
DISCOVERY_MAX_PAGES=10
EXECUTION_TIMEOUT_SEC=120

# In-app updates (GitHub) — notify, show changelog, auto-install + restart
# Data preserved: .env, SQLite DB, data/, execution_artifacts
QEOS_AUTO_UPDATE_ENABLED=true
QEOS_AUTO_UPDATE_POLL_SEC=120
QEOS_AUTO_UPDATE_DEFER_WHEN_BUSY=true

# Cursor Cloud API — optional Discovery advisor (https://cursor.com/docs/cloud-agent/api/endpoints)
# Optional manual override; prefer Connect Cursor in the Discovery UI (browser sign-in).
CURSOR_API_KEY=
DISCOVERY_CURSOR_ADVISOR_ENABLED=true
CURSOR_DISCOVERY_MODEL=composer-2
CURSOR_DISCOVERY_PLAN_TIMEOUT_SEC=90

# SSO (legacy aliases — use QEOS_SSO_* above)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
